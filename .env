# SUPERTABLE
SUPERTABLE_HOME=~/supertable
SUPERTABLE_ORGANIZATION=kladna-soft
SUPERTABLE_SUPERUSER_TOKEN=token
SUPERTABLE_LOGIN_MASK=1


# STORAGE
STORAGE_TYPE=MINIO
STORAGE_REGION=eu-central-1
STORAGE_ENDPOINT_URL=http://192.168.168.130:9000
STORAGE_SPARK_ENDPOINT_URL=http://minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin123!
STORAGE_BUCKET=supertable
STORAGE_FORCE_PATH_STYLE=true
#Path style (STORAGE_FORCE_PATH_STYLE=true):
#http://192.168.168.130:9000/supertable/org/data/file.parquet
#                           bucket is in the path
#Virtual-hosted style (STORAGE_FORCE_PATH_STYLE=false):
#http://supertable.192.168.168.130:9000/org/data/file.parquet
#     bucket is a subdomain

# === Redis auth ===
LOCKING_BACKEND=redis
#SUPERTABLE_REDIS_HOST=localhost
#SUPERTABLE_REDIS_PORT=6379
#SUPERTABLE_REDIS_PASSWORD=change_me_to_a_strong_password
SUPERTABLE_REDIS_DB=1

# SENTINEL
SUPERTABLE_REDIS_SENTINEL=true
SUPERTABLE_REDIS_SENTINELS=redis-sentinel-1:26379,redis-sentinel-2:26379,redis-sentinel-3:26379
SUPERTABLE_REDIS_SENTINEL_MASTER=mymaster
SUPERTABLE_REDIS_SENTINEL_PASSWORD=change_me_to_a_strong_password

# ENGINE
DUCKDB_JE_MALLOC_CONF=background_thread:true
SUPERTABLE_DUCKDB_PRESIGNED=1
SUPERTABLE_DUCKDB_HTTP_TIMEOUT=60
SUPERTABLE_DUCKDB_HTTP_METADATA_CACHE=1
# Memory — both executors, no PINNED variant needed
SUPERTABLE_DUCKDB_MEMORY_LIMIT=8GB
# SUPERTABLE_DUCKDB_THREADS not set     # auto-derived: 20 on 8-core/8GB host
# default multiplier is 3, tune up to 5 if network is fast
SUPERTABLE_DUCKDB_IO_MULTIPLIER=5
# Disk cache
SUPERTABLE_DUCKDB_EXTERNAL_CACHE_SIZE=50GB
SUPERTABLE_DUCKDB_EXTERNAL_CACHE_DIR=~/supertable/duckdb_cache

# ACCESS LAYER

## API
SUPERTABLE_API_HOST=0.0.0.0
SUPERTABLE_API_PORT=8050


## UI
SUPERTABLE_UI_HOST=0.0.0.0
SUPERTABLE_UI_PORT=8051

# ODATA
SUPERTABLE_ODATA_PORT=8052

## MCP
SUPERTABLE_MCP_PORT=8053
SUPERTABLE_MCP_TRANSPORT='streamable-http'  # streamable-http | stdio
SUPERTABLE_REQUIRE_TOKEN=1
SUPERTABLE_MCP_TOKEN=some-strong-random-string



# LOG
SUPERTABLE_LOG_LEVEL='INFO'                 # DEBUG |INFO |WARNING | ERROR
SUPERTABLE_LOG_FORMAT='text'                # json (default) or text
SUPERTABLE_CORRELATION_HEADER='X-Correlation-ID'  # header name



# AUTH
SUPERTABLE_AUTH_MODE=api_key
# api_key | bearer
SUPERTABLE_API_KEY=change-me-super-secret
#SUPERTABLE_BEARER_TOKEN=
SUPERTABLE_AUTH_HEADER_NAME=X-API-Key
