# ── Supertable .env example ──────────────────────────────────────
# Copy to .env and adjust values:
#   cp .env.example .env
#
# Then start:
#   docker compose --profile infra --profile webui up -d

# Required — superuser admin token
SUPERTABLE_SUPERUSER_TOKEN=changeme

# Organization name (your tenant)
SUPERTABLE_ORGANIZATION=my-org

# Storage (MinIO defaults — works with the infra profile)
STORAGE_TYPE=MINIO
STORAGE_ENDPOINT_URL=http://minio:9000
STORAGE_BUCKET=supertable
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin123!
STORAGE_FORCE_PATH_STYLE=true

# Redis (defaults — works with the infra profile)
# SUPERTABLE_REDIS_HOST=redis
# SUPERTABLE_REDIS_PORT=6379

# Optional — session cookie secret (generate a random string for production)
# SUPERTABLE_SESSION_SECRET=

# Optional — MCP shared secret
# SUPERTABLE_MCP_TOKEN=

# Optional — hot reload for development
# UVICORN_RELOAD=1
